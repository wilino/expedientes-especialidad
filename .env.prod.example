# ── Imágenes de aplicación (GHCR) ─────────────────────────────
API_IMAGE=ghcr.io/owner/repo-api:latest
WEB_IMAGE=ghcr.io/owner/repo-web:latest

# ── Puertos expuestos ─────────────────────────────────────────
API_PORT=4000
WEB_PORT=5173
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=expedientes
MYSQL_PASSWORD=expedientes
MYSQL_DATABASE=expedientes

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production_refresh
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Swagger (recomendado false en prod) ──────────────────────
SWAGGER_ENABLED=false
SWAGGER_PATH=docs
SWAGGER_JSON_PATH=docs-json

# ── MinIO / S3 compatible ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=expedientes-docs

DOCUMENTS_STORAGE_DRIVER=minio
DOCUMENTS_STORAGE_PATH=uploads
DOCUMENTS_STORAGE_S3_ENDPOINT=http://minio:9000
DOCUMENTS_STORAGE_S3_REGION=us-east-1
DOCUMENTS_STORAGE_S3_BUCKET=expedientes-docs
DOCUMENTS_STORAGE_S3_PREFIX=
DOCUMENTS_STORAGE_S3_ACCESS_KEY=minioadmin
DOCUMENTS_STORAGE_S3_SECRET_KEY=minioadmin
DOCUMENTS_STORAGE_S3_FORCE_PATH_STYLE=true
