generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ── Usuarios y RBAC ────────────────────────────────────

model Usuario {
  id           String   @id @default(uuid())
  nombre       String
  correo       String   @unique
  password     String
  estado       Boolean  @default(true)
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles       UsuarioRol[]
  expedientes Expediente[] @relation("creador")
  actuaciones Actuacion[]
  documentos  Documento[]
  auditLogs   AuditLog[]
  notificaciones Notificacion[]
  recordatorios  Recordatorio[]

  @@map("usuario")
}

model Rol {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")

  permisos RolPermiso[]
  usuarios UsuarioRol[]

  @@map("rol")
}

model Permiso {
  id          String   @id @default(uuid())
  codigo      String   @unique
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolPermiso[]

  @@map("permiso")
}

model RolPermiso {
  rolId     String @map("rol_id")
  permisoId String @map("permiso_id")

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("rol_permiso")
}

model UsuarioRol {
  usuarioId String @map("usuario_id")
  rolId     String @map("rol_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
  @@map("usuario_rol")
}

// ── Dominio: Expedientes ────────────────────────────────

enum EstadoExpediente {
  ABIERTO
  EN_TRAMITE
  CERRADO
  ARCHIVADO
}

enum NotificacionTipo {
  VENCIMIENTO
  ALERTA
  EXITO
  INFO
}

enum RecursoTipo {
  EXPEDIENTE
  ACTUACION
  DOCUMENTO
  AUDITORIA
  SISTEMA
}

enum RecordatorioPrioridad {
  URGENTE
  NORMAL
  BAJA
}

model Expediente {
  id            String           @id @default(uuid())
  codigo        String           @unique
  caratula      String
  estado        EstadoExpediente @default(ABIERTO)
  fechaApertura DateTime         @default(now()) @map("fecha_apertura")
  creadorId     String           @map("creador_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  creador     Usuario     @relation("creador", fields: [creadorId], references: [id])
  actuaciones Actuacion[]
  documentos  Documento[]
  auditLogs   AuditLog[]

  @@index([codigo])
  @@index([estado])
  @@map("expediente")
}

model Actuacion {
  id           String   @id @default(uuid())
  expedienteId String   @map("expediente_id")
  usuarioId    String   @map("usuario_id")
  tipo         String
  descripcion  String
  resultado    String?
  fecha        DateTime @default(now())
  createdAt    DateTime @default(now()) @map("created_at")

  expediente Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])

  @@map("actuacion")
}

model Documento {
  id           String   @id @default(uuid())
  expedienteId String   @map("expediente_id")
  usuarioId    String   @map("usuario_id")
  nombre       String
  tipo         String
  uri          String
  hash         String
  fecha        DateTime @default(now())
  createdAt    DateTime @default(now()) @map("created_at")

  expediente Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])

  @@map("documento")
}

// ── Auditoría ───────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  usuarioId    String   @map("usuario_id")
  expedienteId String?  @map("expediente_id")
  accion       String
  recurso      String
  resultado    String
  ip           String?
  payload      Json?
  timestamp    DateTime @default(now())

  usuario    Usuario     @relation(fields: [usuarioId], references: [id])
  expediente Expediente? @relation(fields: [expedienteId], references: [id])

  @@index([timestamp])
  @@index([usuarioId])
  @@index([expedienteId])
  @@map("audit_log")
}

model Notificacion {
  id          String           @id @default(uuid())
  usuarioId   String           @map("usuario_id")
  tipo        NotificacionTipo
  titulo      String
  mensaje     String?
  recursoId   String?          @map("recurso_id")
  recursoTipo RecursoTipo?     @map("recurso_tipo")
  leida       Boolean          @default(false)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida])
  @@index([createdAt])
  @@map("notificaciones")
}

model Recordatorio {
  id          String               @id @default(uuid())
  usuarioId   String               @map("usuario_id")
  titulo      String
  descripcion String?
  fechaHora   DateTime             @map("fecha_hora")
  prioridad   RecordatorioPrioridad @default(NORMAL)
  completado  Boolean              @default(false)
  recursoId   String?              @map("recurso_id")
  recursoTipo RecursoTipo?         @map("recurso_tipo")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, fechaHora])
  @@index([usuarioId, completado])
  @@map("recordatorios")
}
